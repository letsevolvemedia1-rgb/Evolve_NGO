generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubmissionStatus {
  NEW
  IN_REVIEW
  CLOSED
  SPAM
}

enum DonationStatus {
  INTENT
  CONTACTED
  RECEIPT_PENDING
  COMPLETED
  CANCELLED
}

enum InquiryType {
  VOLUNTEER
  INTERNSHIP
  CORPORATE
  DONATION
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OfficeType {
  HEAD_OFFICE
  REGISTERED_OFFICE
  OTHER
}

model Campaign {
  id             String           @id @default(cuid())
  slug           String           @unique
  causeCode      String           @unique
  title          String
  formTitle      String
  overlayTop     String?
  overlayBottom  String?
  heroImage      String?
  summary        String?
  bodyContent    Json?
  status         CampaignStatus   @default(ACTIVE)
  sortOrder      Int              @default(0)
  isFeatured     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  donationIntents DonationIntent[]

  @@index([status, sortOrder])
}

model DonationIntent {
  id               String         @id @default(cuid())
  campaignId       String?
  campaignLabel    String?
  donorName        String
  email            String
  phone            String
  amountInr        Int
  dateOfBirth      DateTime?
  panNumber        String?
  country          String         @default("India")
  state            String?
  city             String?
  address          String?
  pincode          String?
  consentToContact Boolean        @default(false)
  sourcePage       String         @default("support-a-cause")
  notes            String?
  status           DonationStatus @default(INTENT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  campaign         Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([email, createdAt])
  @@index([status, createdAt])
}

model ContactSubmission {
  id         String           @id @default(cuid())
  name       String
  phone      String
  email      String
  message    String
  sourcePage String           @default("contact-us")
  status     SubmissionStatus @default(NEW)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([email, createdAt])
}

model EngagementInquiry {
  id         String           @id @default(cuid())
  type       InquiryType
  name       String
  email      String
  phone      String
  message    String?
  sourcePage String           @default("join-us")
  status     SubmissionStatus @default(NEW)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([type, createdAt])
  @@index([status, createdAt])
  @@index([email, createdAt])
}

model ContactChannel {
  id            String    @id @default(cuid())
  label         String
  department    String?
  contactPerson String?
  phone         String?
  email         String?
  sortOrder     Int       @default(0)
  isPublic      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isPublic, sortOrder])
}

model OfficeLocation {
  id          String     @id @default(cuid())
  label       String
  officeType  OfficeType @default(OTHER)
  addressLine1 String
  addressLine2 String?
  city        String?
  state       String?
  postalCode  String?
  country     String     @default("India")
  phone       String?
  email       String?
  isPrimary   Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([officeType, sortOrder])
}

model SocialLink {
  id         String   @id @default(cuid())
  platform   String
  label      String?
  url        String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
}
